# Obsidian vault path
OBSIDIAN_BRIDGE_VAULT_PATH=~/SecondMind

# ChromaDB storage path  
OBSIDIAN_BRIDGE_CHROMA_PATH=~/.obsidian-bridge/chroma

# Embedding model
OBSIDIAN_BRIDGE_EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- Hybrid Search (v0.2.0) ---
# Enable hybrid search: vector + BM25 keyword (true/false)
OBSIDIAN_BRIDGE_HYBRID_SEARCH=true

# Enable Cross-Encoder reranking for precise results (true/false)
OBSIDIAN_BRIDGE_RERANKING=true

# Reranker model (local, ~90MB, no API calls)
OBSIDIAN_BRIDGE_RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# BM25/Vector weights for RRF fusion (default 1.0 each)
OBSIDIAN_BRIDGE_BM25_WEIGHT=1.0
OBSIDIAN_BRIDGE_VECTOR_WEIGHT=1.0

# Over-fetch multiplier for reranking (fetch N*multiplier, rerank to N)
OBSIDIAN_BRIDGE_RETRIEVAL_MULTIPLIER=3
